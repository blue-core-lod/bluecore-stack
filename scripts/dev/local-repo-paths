#!/usr/bin/env bash

# Shared default paths for local Blue Core service checkouts.
#
# Scripts source this file after setting ROOT_DIR. Existing environment values
# are preserved, so developers can point individual services at nonstandard
# checkout locations without editing every helper script.

: "${LOCAL_BLUECORE_API_DIR:=$ROOT_DIR/../bluecore_api}"
: "${LOCAL_BLUECORE_WORKFLOWS_DIR:=$ROOT_DIR/../bluecore-workflows}"
: "${LOCAL_BLUECORE_MODELS_DIR:=$ROOT_DIR/../bluecore-models}"
: "${LOCAL_MARVA_DIR:=$ROOT_DIR/../marva_editor}"
: "${LOCAL_SINOPIA_DIR:=$ROOT_DIR/../sinopia_editor}"

export LOCAL_BLUECORE_API_DIR
export LOCAL_BLUECORE_WORKFLOWS_DIR
export LOCAL_BLUECORE_MODELS_DIR
export LOCAL_MARVA_DIR
export LOCAL_SINOPIA_DIR
